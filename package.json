{
  "name": "buddy-harmony",
  "version": "0.11.1",
  "homepage": "https://Marthijs-Berfelo.github.io/buddy-harmony",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "eslint src --fix",
    "commit": "cz",
    "release": "release-it",
    "release:ci": "release-it --ci",
    "release:ci-prepare": "echo $(release-it --ci --release-version) > next-version.txt",
    "release:milestone": "release-it minor --ci",
    "release:milestone-prepare": "echo $(release-it minor --ci --release-version) > next-version.txt",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@fortawesome/fontawesome-common-types": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@material-tailwind/react": "^2.1.10",
    "@tombatossals/chords-db": "^0.5.1",
    "@tonaljs/tonal": "^4.10.0",
    "assert-ts": "^0.3.4",
    "guitar-scales": "^1.0.4",
    "i18next": "^26.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-flags-select": "^2.5.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.0.0",
    "react-to-print": "^3.0.0",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-fontawesome": "^1.6.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "commitizen": "^4.3.1",
    "cosmiconfig": "^9.0.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "gh-pages": "^6.0.0",
    "globals": "^15.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.0.0",
    "release-it": "^20.0.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "eslint --fix"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "release-it": {
    "git": {
      "requiresBranch": "release/**",
      "commitMessage": "chore: release v${version}",
      "requireUpstream": false
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits"
        },
        "infile": "CHANGELOG.md"
      }
    }
  }
}
